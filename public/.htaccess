RewriteEngine On

# Compress text assets with Brotli/Gzip when supported by Apache modules.
<IfModule mod_brotli.c>
	AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/css text/javascript application/javascript application/x-javascript application/json application/xml image/svg+xml
</IfModule>

<IfModule mod_deflate.c>
	AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/x-javascript application/json application/xml image/svg+xml
</IfModule>

# Long cache for static assets served from /assets with URL fingerprinting.
<IfModule mod_expires.c>
	ExpiresActive On
	ExpiresByType text/css "access plus 1 year"
	ExpiresByType text/javascript "access plus 1 year"
	ExpiresByType application/javascript "access plus 1 year"
	ExpiresByType image/jpeg "access plus 1 year"
	ExpiresByType image/png "access plus 1 year"
	ExpiresByType image/webp "access plus 1 year"
	ExpiresByType image/svg+xml "access plus 1 year"
	ExpiresByType font/woff2 "access plus 1 year"
	ExpiresByType font/woff "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
	<FilesMatch "\.(?:css|js|mjs|png|jpe?g|webp|svg|woff2?|ico)$">
		Header set Cache-Control "public, max-age=31536000, immutable"
	</FilesMatch>
	<FilesMatch "\.(?:html|php)$">
		Header set Cache-Control "no-cache, no-store, must-revalidate"
	</FilesMatch>
</IfModule>

# SEO category URL: /category/slug-123.html -> front controller /category?id=123
RewriteRule ^category/([a-z0-9-]+)-([0-9]+)\.html$ index.php?route=category&id=$2 [QSA,L,NC]

# SEO article URL: /slug-123.html -> /article?id=123
RewriteRule ^([a-z0-9-]+)-([0-9]+)\.html$ article?id=$2 [QSA,L,NC]

# If the requested file or directory exists, serve it directly.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Otherwise route all requests through the front controller.
RewriteRule ^ index.php [QSA,L]
