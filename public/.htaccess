RewriteEngine On

# SEO category URL: /category/slug-123.html -> front controller /category?id=123
RewriteRule ^category/([a-z0-9-]+)-([0-9]+)\.html$ index.php?route=category&id=$2 [QSA,L,NC]

# SEO article URL: /slug-123.html -> /article?id=123
RewriteRule ^([a-z0-9-]+)-([0-9]+)\.html$ article?id=$2 [QSA,L,NC]

# If the requested file or directory exists, serve it directly.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Otherwise route all requests through the front controller.
RewriteRule ^ index.php [QSA,L]
